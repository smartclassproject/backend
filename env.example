# MongoDB Atlas Connection String
# Replace <username>, <password>, <cluster-url>, and <database-name> with your actual values
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority

# Server Configuration
PORT=5000
NODE_ENV=development

# Swagger "Try it out" base URL (optional). Example when API is on a LAN IP:
# SWAGGER_SERVER_URL=http://41.186.188.119:5000
# If unset, defaults to http://localhost:PORT (fine for local dev only).

# When the public API is only ever served over HTTPS (e.g. TLS at nginx, or PUBLIC_API_BASE_URL=https://...),
# set HELMET_ASSUME_HTTPS_SITE=true so Helmet keeps strict CSP (upgrade-insecure-requests) and COOP/OAC.
# Leave unset for plain http://IP:port so /api-docs assets load over HTTP without SSL errors.
# HELMET_ASSUME_HTTPS_SITE=true
# PUBLIC_API_BASE_URL=https://api.example.com

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=10485760

# CORS Configuration
FRONTEND_URL=http://localhost:5173
# Comma-separated explicit origins for production, e.g.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://app.yourdomain.com
# Optional domain suffix patterns, e.g. .yourdomain.com
# FRONTEND_URL_PATTERNS=.yourdomain.com
# Dev-only shortcut (do not enable in production):
# ALLOW_ALL_ORIGINS=true

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=RiseMe <noreply@yourdomain.com>
# Optional local logo path (relative to backend root) for inline email logo
# BRAND_LOGO_PATH=assets/logo.png
# Optional public logo URL used in branded HTML emails
# BRAND_LOGO_URL=https://your-domain.com/logo.png

# Password Reset Configuration
PASSWORD_RESET_EXPIRES_IN=1h
FRONTEND_PASSWORD_SETUP_URL=http://localhost:5173/setup-password

# Email Retry Configuration
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_MS=2000
EMAIL_CONNECTION_POOL_SIZE=5

# Optional: Redis for session storage (if needed)
# REDIS_URL=redis://localhost:6379 